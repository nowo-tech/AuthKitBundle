{# Demo locale switcher — keeps the same page and swaps {_locale} in the URL #}
<nav class="locale-switcher d-flex gap-2"
     role="navigation"
     aria-label="{{ 'demo.locale.nav'|trans({}, 'demo') }}">
    {% set route = app.request.attributes.get('_route') %}
    {% set route_params = app.request.attributes.get('_route_params')|default({}) %}
    {% for locale in ['en', 'es'] %}
        {% set params = route ? route_params|merge({'_locale': locale}) : {'_locale': locale} %}
        {% set target_route = route ?: 'app_welcome' %}
        <a href="{{ path(target_route, params) }}"
           class="btn btn-sm {{ app.request.locale == locale ? 'btn-primary' : 'btn-outline-secondary' }}"
           hreflang="{{ locale }}"
           lang="{{ locale }}">
            {{ ('demo.locale.' ~ locale)|trans({}, 'demo') }}
        </a>
    {% endfor %}
</nav>
