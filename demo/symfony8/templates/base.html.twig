<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ 'demo.home.title'|trans({}, 'demo') }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="{{ asset('css/demo-auth.css') }}">
</head>
<body class="bg-body-tertiary min-vh-100 d-flex flex-column">
    <nav class="navbar navbar-expand bg-white border-bottom shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="{{ path('app_welcome', auth_kit_route_params()) }}">{{ 'demo.home.title'|trans({}, 'demo') }}</a>
            <div class="d-flex align-items-center gap-2 ms-auto">
                {% include 'demo/_locale_switcher.html.twig' %}
                {{ auth_kit_dropdown({form_theme: 'form/auth_kit_theme.html.twig'}) }}
            </div>
        </div>
    </nav>
    <div class="container py-5 flex-grow-1">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        {% block body %}{% endblock %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
