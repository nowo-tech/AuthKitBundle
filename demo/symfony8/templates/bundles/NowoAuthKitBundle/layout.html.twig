{#
    Override: templates/bundles/NowoAuthKitBundle/layout.html.twig
    Replaces @NowoAuthKitBundle/layout.html.twig for login and register pages.
#}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ 'layout.title'|trans({}, 'NowoAuthKitBundle') }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="{{ asset('bundles/nowopasswordtoggle/css/toggle_password.css') }}">
    <link rel="stylesheet" href="{{ asset('css/demo-auth.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-body-tertiary min-vh-100 d-flex flex-column">
    <main class="container flex-grow-1 d-flex align-items-center py-5">
        <div class="w-100 mx-auto" style="max-width: 28rem;">
            {% include 'demo/_locale_switcher.html.twig' %}
            {% block body %}{% endblock %}
        </div>
    </main>
    {% block javascripts %}{% endblock %}
</body>
</html>
