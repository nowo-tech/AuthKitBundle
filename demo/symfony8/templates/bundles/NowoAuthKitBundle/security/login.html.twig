{#
    Override: templates/bundles/NowoAuthKitBundle/security/login.html.twig
#}
{% extends layout_template %}

{% block title %}{{ 'login.title'|trans({}, 'NowoAuthKitBundle') }}{% endblock %}

{% block body %}
{% form_theme login_form 'form/auth_kit_theme.html.twig' %}
<div class="card shadow-sm border-0 auth-card">
    <div class="card-body p-4">
        <div class="auth-card__header">
            <h1 class="h4 mb-0 fw-semibold">{{ 'login.heading'|trans({}, 'NowoAuthKitBundle') }}</h1>
        </div>

        {% if error %}
            <div class="alert alert-danger py-2 mb-3" role="alert">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {{ form_start(login_form, {attr: {class: 'vstack gap-3'}}) }}
            {{ form_row(login_form._username, {row_attr: {class: 'mb-0'}}) }}
            {{ form_row(login_form._password, {row_attr: {class: 'mb-0'}}) }}
            {% if login_form._remember_me is defined %}
                {{ form_row(login_form._remember_me, {row_attr: {class: 'mb-0'}}) }}
            {% endif %}
            <div class="pt-1">
                <button type="submit" class="btn btn-primary w-100 btn-lg">{{ 'login.submit'|trans({}, 'NowoAuthKitBundle') }}</button>
            </div>
        {{ form_end(login_form) }}

        <div class="auth-card__footer">
            <a href="{{ path(register_route) }}" class="link-primary text-decoration-none fw-medium">{{ 'login.register_link'|trans({}, 'NowoAuthKitBundle') }}</a>
        </div>
    </div>
</div>
{% endblock %}
