{% extends layout_template %}

{% block title %}{{ 'reset.request.title'|trans({}, 'NowoAuthKitBundle') }}{% endblock %}

{% block body %}
{% form_theme reset_request_form '@NowoPasswordToggleBundle/Form/toggle_password_widget.html.twig' %}
<section class="nowo-auth-kit__panel">
    <h1>{{ 'reset.request.heading'|trans({}, 'NowoAuthKitBundle') }}</h1>
    <p>{{ 'reset.request.help'|trans({}, 'NowoAuthKitBundle') }}</p>

    {{ form_start(reset_request_form) }}
        {{ form_row(reset_request_form.identifier) }}
        <button type="submit" class="nowo-auth-kit__button">{{ 'reset.request.submit'|trans({}, 'NowoAuthKitBundle') }}</button>
    {{ form_end(reset_request_form) }}

    <p class="nowo-auth-kit__footer">
        <a href="{{ path(login_route, auth_kit_route_params()) }}">{{ 'reset.request.back_to_login'|trans({}, 'NowoAuthKitBundle') }}</a>
    </p>
</section>
{% endblock %}
