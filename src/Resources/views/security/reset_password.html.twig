{% extends layout_template %}

{% block title %}{{ 'reset.password.title'|trans({}, 'NowoAuthKitBundle') }}{% endblock %}

{% block body %}
{% form_theme reset_password_form '@NowoPasswordToggleBundle/Form/toggle_password_widget.html.twig' %}
<section class="nowo-auth-kit__panel">
    <h1>{{ 'reset.password.heading'|trans({}, 'NowoAuthKitBundle') }}</h1>

    {{ form_start(reset_password_form) }}
        {{ form_row(reset_password_form.password) }}
        <button type="submit" class="nowo-auth-kit__button">{{ 'reset.password.submit'|trans({}, 'NowoAuthKitBundle') }}</button>
    {{ form_end(reset_password_form) }}

    <p class="nowo-auth-kit__footer">
        <a href="{{ path(login_route, auth_kit_route_params()) }}">{{ 'reset.password.back_to_login'|trans({}, 'NowoAuthKitBundle') }}</a>
    </p>
</section>
{% endblock %}
